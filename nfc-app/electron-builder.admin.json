{
  "appId": "com.easyorder.admin",
  "productName": "EasyOrder Admin Panel",
  "directories": {
    "output": "release/admin"
  },
  "files": [
    "out/**/*",
    "data/**/*",
    "client/**/*",
    "node_modules/**/*",
    "package.json"
  ],
  "extraResources": [
    {
      "from": "data",
      "to": "data"
    },
    {
      "from": "client",
      "to": "client"
    },
    {
      "from": "imgs",
      "to": "imgs"
    }
  ],
  "win": {
    "target": [
      "nsis"
    ],
    "executableName": "EasyOrderAdmin",
    "icon": "imgs/logo_icon.ico",
    "signAndEditExecutable": false,
    "sign": null
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "installerSidebar": null,
    "installerIcon": "imgs/logo_icon.ico",
    "uninstallerIcon": "imgs/logo_icon.ico",
    "createDesktopShortcut": "always",
    "createStartMenuShortcut": true,
    "shortcutName": "EasyOrder Admin Panel"
  }
}
